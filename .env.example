# Grafana Alloy — environment template. Copy to .env and fill in:
#   cp .env.example .env
# .env is gitignored; this template is safe to commit (no secrets).

# --- Grafana Cloud: Prometheus remote_write (basic auth) ---
# Grafana Cloud stack -> Connections -> Prometheus -> "Sending metrics".
METRICS_PRIMARY_URL=https://<stack>.grafana.net/api/prom/push
METRICS_PRIMARY_USER=<instance-id>
METRICS_PRIMARY_PASSWORD=<grafana-cloud-api-token>

# --- Grafana Cloud: Loki (logs, basic auth) ---
# Grafana Cloud stack -> Connections -> Loki -> "Sending logs".
LOGS_PRIMARY_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
LOGS_PRIMARY_USER=<loki-instance-id>
LOGS_PRIMARY_PASSWORD=<grafana-cloud-api-token>

# --- Optional external labels added to every series ---
CLUSTER_NAME=alloy-local
ENV=dev
REGION=

# --- Runtime ---
ALLOY_VERSION=v1.11.3
SCENARIO=grafanacloud
