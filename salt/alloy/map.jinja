{#-
  alloy salt formula — per-host settings from pillar (`alloy:`).

  pillar example (see pillar.example.sls):
    alloy:
      version: "1.10.2"
      scenario: linux            # linux | proxmox | windows | batocera
      repo_url: https://raw.githubusercontent.com/cznewt/alloy-resources/main
      env:                       # written to the service environment (sys.env)
        METRICS_PRIMARY_URL: ...
        METRICS_PRIMARY_USER: ...
        METRICS_PRIMARY_PASSWORD: ...
        LOGS_PRIMARY_URL: ...
        LOGS_PRIMARY_USER: ...
        LOGS_PRIMARY_PASSWORD: ...
        CLUSTER_NAME: ...
-#}
{% set p = salt['pillar.get']('alloy', {}) %}
{% set alloy = {
     'version':  p.get('version', '1.10.2'),
     'scenario': p.get('scenario', 'linux'),
     'repo_url': p.get('repo_url', 'https://raw.githubusercontent.com/cznewt/alloy-resources/main'),
     'env':      p.get('env', {}),
   } %}
{% set release = 'https://github.com/grafana/alloy/releases/download/v' ~ alloy.version %}
